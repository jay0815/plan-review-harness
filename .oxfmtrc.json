{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 120,
  "tabWidth": 2,
  "useTabs": false,
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "embeddedLanguageFormatting": "auto",
  "sortPackageJson": true,
  "ignorePatterns": ["node_modules/**", "dist/**", "coverage/**", "runs/**", "tests/fixtures/malformed/**"]
}
