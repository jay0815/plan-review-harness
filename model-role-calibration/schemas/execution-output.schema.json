{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Execution Reviewer Output",
  "type": "object",
  "required": [
    "probe",
    "coverage_declaration",
    "issues",
    "missing_questions",
    "false_positive_risks"
  ],
  "properties": {
    "probe": {
      "const": "execution"
    },
    "coverage_declaration": {
      "type": "object",
      "required": [
        "reviewed_boundaries",
        "unverified_assumptions",
        "not_reviewed"
      ],
      "properties": {
        "reviewed_boundaries": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": [
              "boundary",
              "status",
              "evidence_basis",
              "notes"
            ],
            "properties": {
              "boundary": {
                "enum": [
                  "main_path",
                  "step_order",
                  "dependencies",
                  "inputs",
                  "outputs",
                  "acceptance",
                  "tests",
                  "failure_semantics",
                  "rollback_or_recovery",
                  "compatibility_or_release",
                  "implementation_discretion",
                  "plan_bloat"
                ]
              },
              "status": {
                "enum": [
                  "covered",
                  "partially_covered",
                  "not_covered",
                  "not_applicable"
                ]
              },
              "evidence_basis": {
                "enum": [
                  "plan_text",
                  "existing_code_refs",
                  "plan_and_existing_code_refs",
                  "missing_context"
                ]
              },
              "notes": {
                "type": "string"
              }
            },
            "additionalProperties": false
          }
        },
        "unverified_assumptions": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "not_reviewed": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "type",
          "severity",
          "evidence",
          "why_it_matters",
          "required_plan_detail",
          "blocks_execution",
          "confidence"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "step",
              "dependency",
              "input",
              "output",
              "acceptance",
              "test",
              "ambiguity",
              "plan_bloat",
              "preference"
            ]
          },
          "severity": {
            "enum": ["low", "medium", "high", "blocker"]
          },
          "evidence": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "required_plan_detail": {
            "type": "string"
          },
          "blocks_execution": {
            "type": "boolean"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "missing_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "false_positive_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
