{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Planner Probe Model Output",
  "type": "object",
  "required": [
    "probe",
    "summary",
    "plan_complexity",
    "engineering_context",
    "scope",
    "decisions",
    "implementation_steps",
    "failure_handling",
    "test_plan",
    "acceptance_criteria",
    "blocking_decisions",
    "implementation_discretion",
    "open_decisions",
    "risks"
  ],
  "properties": {
    "probe": {
      "const": "planner"
    },
    "summary": {
      "type": "string"
    },
    "plan_complexity": {
      "type": "object",
      "required": ["level", "reason"],
      "properties": {
        "level": {
          "enum": ["single_file", "feature", "cross_feature", "architecture"]
        },
        "reason": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "engineering_context": {
      "type": "object",
      "required": ["project_type", "reason", "focus_areas"],
      "properties": {
        "project_type": {
          "enum": ["frontend", "backend", "fullstack", "unknown"]
        },
        "reason": {
          "type": "string"
        },
        "focus_areas": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "decision", "reason", "basis", "evidence_refs"],
        "properties": {
          "title": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          },
          "basis": {
            "type": "array",
            "minItems": 1,
            "items": {
              "enum": ["requirement", "existing_code", "engineering_constraint"]
            }
          },
          "evidence_refs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "implementation_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "title", "details", "dependencies", "outputs"],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "failure_handling": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "blocking_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "implementation_discretion": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
