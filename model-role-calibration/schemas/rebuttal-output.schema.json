{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Independent Critical Reviewer Output",
  "type": "object",
  "required": ["probe", "issues", "missing_questions", "false_positive_risks"],
  "properties": {
    "probe": {
      "const": "rebuttal"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "title",
          "type",
          "severity",
          "evidence",
          "why_it_matters",
          "required_plan_change",
          "confidence"
        ],
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "defect",
              "risk",
              "assumption",
              "contradiction",
              "missing_constraint",
              "preference"
            ]
          },
          "severity": {
            "enum": ["low", "medium", "high", "blocker"]
          },
          "evidence": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "required_plan_change": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "missing_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "false_positive_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
