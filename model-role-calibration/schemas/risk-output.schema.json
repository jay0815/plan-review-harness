{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Risk Review Probe Model Output",
  "type": "object",
  "required": ["probe", "issues", "missing_questions", "false_positive_risks"],
  "properties": {
    "probe": {
      "const": "risk"
    },
    "issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "type", "severity", "evidence", "why_it_matters", "confidence"],
        "properties": {
          "title": {
            "type": "string"
          },
          "type": {
            "enum": [
              "risk",
              "assumption",
              "compatibility",
              "rollback",
              "observability",
              "data",
              "security",
              "scope",
              "preference"
            ]
          },
          "severity": {
            "enum": ["low", "medium", "high", "blocker"]
          },
          "evidence": {
            "type": "string"
          },
          "why_it_matters": {
            "type": "string"
          },
          "confidence": {
            "type": "number",
            "minimum": 0,
            "maximum": 1
          }
        },
        "additionalProperties": false
      }
    },
    "missing_questions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "false_positive_risks": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
