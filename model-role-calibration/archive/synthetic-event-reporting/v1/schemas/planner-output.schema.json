{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Planner Probe Model Output",
  "type": "object",
  "required": [
    "probe",
    "summary",
    "scope",
    "decisions",
    "implementation_steps",
    "failure_handling",
    "test_plan",
    "acceptance_criteria",
    "open_decisions"
  ],
  "properties": {
    "probe": {
      "const": "planner"
    },
    "summary": {
      "type": "string"
    },
    "scope": {
      "type": "object",
      "required": ["in_scope", "out_of_scope"],
      "properties": {
        "in_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "out_of_scope": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "decisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "decision", "reason"],
        "properties": {
          "title": {
            "type": "string"
          },
          "decision": {
            "type": "string"
          },
          "reason": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    },
    "implementation_steps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["order", "title", "details", "dependencies", "outputs"],
        "properties": {
          "order": {
            "type": "integer",
            "minimum": 1
          },
          "title": {
            "type": "string"
          },
          "details": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "failure_handling": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "test_plan": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "open_decisions": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
