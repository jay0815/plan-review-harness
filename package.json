{
  "name": "plan-review-harness",
  "version": "1.0.0",
  "description": "Plan Review Harness runtime spike",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "bin": {
    "plan-review": "./dist/cli/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "plan-review": "node --import tsx src/cli/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "lint": "oxlint --disable-nested-config src tests vite.config.ts vitest.config.ts",
    "lint:fix": "oxlint --disable-nested-config --fix src tests vite.config.ts vitest.config.ts",
    "fmt": "oxfmt --disable-nested-config \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\" \"wiki/**/*.md\" \"fixtures/**/*.md\" \"fixtures/mock/**/*.json\" \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \"vitest.config.ts\" \".oxlintrc.json\" \".oxfmtrc.json\"",
    "fmt:check": "oxfmt --disable-nested-config --check \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\" \"wiki/**/*.md\" \"fixtures/**/*.md\" \"fixtures/mock/**/*.json\" \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \"vitest.config.ts\" \".oxlintrc.json\" \".oxfmtrc.json\"",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@langchain/langgraph": "^0.4.9",
    "commander": "^14.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "8.1.0",
    "vitest": "^4.0.15"
  },
  "packageManager": "pnpm@10.26.0"
}
