{
  "name": "plan-review-harness",
  "version": "1.0.0",
  "description": "Plan Review Harness runtime spike",
  "keywords": [],
  "license": "ISC",
  "author": "",
  "bin": {
    "plan-review": "./dist/cli/index.js"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "plan-review": "node --import tsx src/cli/index.ts",
    "typecheck": "tsc --noEmit",
    "build": "vite build && tsc -p tsconfig.build.json --emitDeclarationOnly",
    "lint": "oxlint --disable-nested-config src tests vite.config.ts vitest.config.ts",
    "lint:fix": "oxlint --disable-nested-config --fix src tests vite.config.ts vitest.config.ts",
    "fmt": "oxfmt --disable-nested-config \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\" \"wiki/**/*.md\" \"fixtures/**/*.md\" \"fixtures/mock/**/*.json\" \"model-role-calibration/package.json\" \"model-role-calibration/tsconfig.json\" \"model-role-calibration/scripts/**/*.ts\" \"model-role-calibration/types/**/*.d.ts\" \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \"vitest.config.ts\" \".oxlintrc.json\" \".oxfmtrc.json\"",
    "fmt:check": "oxfmt --disable-nested-config --check \"src/**/*.ts\" \"tests/**/*.ts\" \"docs/**/*.md\" \"wiki/**/*.md\" \"fixtures/**/*.md\" \"fixtures/mock/**/*.json\" \"model-role-calibration/package.json\" \"model-role-calibration/tsconfig.json\" \"model-role-calibration/scripts/**/*.ts\" \"model-role-calibration/types/**/*.d.ts\" \"package.json\" \"tsconfig*.json\" \"vite.config.ts\" \"vitest.config.ts\" \".oxlintrc.json\" \".oxfmtrc.json\"",
    "test:watch": "vitest",
    "calibration:create-case": "node --import tsx model-role-calibration/scripts/create-case.ts",
    "calibration:generate-prompts": "node --import tsx model-role-calibration/scripts/generate-prompts.ts",
    "calibration:run": "node --import tsx model-role-calibration/scripts/run-calibration.ts",
    "calibration:run-model": "node --import tsx model-role-calibration/scripts/run-model.ts",
    "calibration:run-pool": "node --import tsx model-role-calibration/scripts/run-agent-pool.ts",
    "calibration:ingest-output": "node --import tsx model-role-calibration/scripts/ingest-output.ts",
    "calibration:score-output": "node --import tsx model-role-calibration/scripts/score-output.ts",
    "calibration:evaluate": "node --import tsx model-role-calibration/scripts/run-evaluation.ts",
    "calibration:promote-evaluation": "node --import tsx model-role-calibration/scripts/promote-evaluation.ts",
    "plan-review:mcp": "node --import tsx model-role-calibration/scripts/plan-review-mcp.ts",
    "plan-review:validate": "node --import tsx model-role-calibration/scripts/plan-review-mcp.ts --validate-only",
    "plan-review:package": "node --import tsx model-role-calibration/scripts/package-claude-distribution.ts",
    "plan-review:inspect": "node --import tsx model-role-calibration/scripts/inspect-workspace-run.ts",
    "plan-review:verify-run": "node --import tsx model-role-calibration/scripts/verify-workspace-review-run.ts",
    "plan-review:doctor": "node --import tsx model-role-calibration/scripts/doctor-workspace-review-run.ts",
    "fact-check:create-case": "node --import tsx model-role-calibration/scripts/create-fact-check-calibration-case.ts",
    "fact-check:generate-prompts": "node --import tsx model-role-calibration/scripts/generate-fact-check-prompts.ts",
    "fact-check:run": "node --import tsx model-role-calibration/scripts/run-fact-check-calibration.ts",
    "fact-check:ingest-output": "node --import tsx model-role-calibration/scripts/ingest-fact-check-output.ts",
    "fact-check:score-output": "node --import tsx model-role-calibration/scripts/score-fact-check-output.ts",
    "fact-check:summarize": "node --import tsx model-role-calibration/scripts/summarize-fact-check-calibration.ts",
    "calibration:summarize-results": "node --import tsx model-role-calibration/scripts/summarize-results.ts",
    "plan-review:lint-plan": "node --import tsx model-role-calibration/scripts/plan-authoring-lint.ts",
    "test": "vitest run",
    "calibration:test": "pnpm calibration:typecheck && node --import tsx model-role-calibration/scripts/validate-fixtures.ts && node --import tsx model-role-calibration/scripts/test-calibration.ts && node --import tsx model-role-calibration/scripts/test-evaluation.ts && node --import tsx model-role-calibration/scripts/test-plan-review-mcp.ts && node --import tsx model-role-calibration/scripts/test-claude-distribution.ts && node --import tsx model-role-calibration/scripts/test-workspace-review-verification.ts && node --import tsx model-role-calibration/scripts/test-fact-check-calibration.ts && node --import tsx model-role-calibration/scripts/test-runtime-integration.ts && node --import tsx model-role-calibration/scripts/test-plan-authoring-lint.ts",
    "calibration:typecheck": "tsc -p model-role-calibration/tsconfig.json --noEmit"
  },
  "dependencies": {
    "commander": "^14.0.0",
    "zod": "^4.1.13"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "oxfmt": "^0.56.0",
    "oxlint": "^1.71.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vite": "8.1.0",
    "vitest": "^4.0.15"
  },
  "engines": {
    "node": ">=22.18.0",
    "pnpm": ">=10.26.0"
  },
  "packageManager": "pnpm@10.26.0"
}
